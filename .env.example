# ABSpider Recon — environment variables
# Copy this file to `.env` and replace the placeholders below with your own
# values. NEVER commit a populated `.env` file to source control.
#
# Frontend (Vite) — variables exposed to the browser MUST be prefixed with
# `VITE_`. Anything unprefixed is server-side only and will not reach the
# client bundle.

# Supabase project URL (e.g. https://YOUR-PROJECT-REF.supabase.co)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase anonymous (publishable) key. The anon key is safe to ship to the
# browser; protect your data with Row Level Security, not by hiding this key.
VITE_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional third-party API keys used by the reconnaissance modules. Store
# real values in your hosting provider's secret manager, not in `.env`.
VITE_SHODAN_API_KEY=replace-with-your-shodan-api-key
VITE_VIRUSTOTAL_API_KEY=replace-with-your-virustotal-api-key
VITE_SECURITYTRAILS_API_KEY=replace-with-your-securitytrails-api-key
VITE_HUNTER_API_KEY=replace-with-your-hunter-io-api-key

# Discord webhook used for scan notifications. Treat as a secret: anyone
# with this URL can post into the channel.
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE/WITH-WEBHOOK
