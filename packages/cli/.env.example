# Optional API keys for enriched passive reconnaissance.
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
BUILTWITH_API_KEY=
OPENCAGE_API_KEY=

# Vite-style aliases are also supported by the CLI.
VITE_SECURITYTRAILS_API_KEY=
VITE_VIRUSTOTAL_API_KEY=
VITE_BUILTWITH_API_KEY=
VITE_OPENCAGE_API_KEY=

# Set to 1 to disable npm auto-update checks.
ABSPIDER_NO_UPDATE=0

# Set to 1 to print auto-update check failures for troubleshooting.
ABSPIDER_UPDATE_DEBUG=0
